{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cleanup-expired-quests",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/post-leaderboard",
      "schedule": "0 9,21 * * *"
    }
  ]
}